# TrueScout — Environment variables
# Copy to .env and fill in your values.  NEVER commit .env to git.

# ---------------------------------------------------------------------------
# API Keys
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-...

# ---------------------------------------------------------------------------
# Storage paths  (defaults shown — override only if you move the data dir)
# ---------------------------------------------------------------------------
DUCKDB_PATH=data/truescout.duckdb
PARQUET_BRONZE_DIR=data/bronze
PARQUET_SILVER_DIR=data/silver
PARQUET_GOLD_DIR=data/gold

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# ---------------------------------------------------------------------------
# CORS  (JSON array — add your Vercel preview URL in production)
# ---------------------------------------------------------------------------
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ---------------------------------------------------------------------------
# Modeling
# ---------------------------------------------------------------------------
MC_ITERATIONS=10000
# Players below this confidence score are routed to the "Traditional Scout"
# LLM voice instead of the metrics-driven "Data Analyst" voice.
CONFIDENCE_SCORE_THRESHOLD=0.4
