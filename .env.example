# TrueScout — Environment variables
# Copy to .env and fill in your values.  NEVER commit .env to git.

# ---------------------------------------------------------------------------
# API Keys
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-...
# Model for narrative generation — free tier works fine for V1
# See https://openrouter.ai/models for options
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Google AI (Gemini) — used by etl/models/generate_narratives.py for
# offline narrative pre-generation.  Get a free key at aistudio.google.com.
GOOGLE_AI_API_KEY=AIza...
# Optional: override the model (default: gemini-2.5-flash)
# GOOGLE_AI_MODEL=gemini-2.5-flash

# ---------------------------------------------------------------------------
# Storage paths  (defaults shown — override only if you move the data dir)
# ---------------------------------------------------------------------------
DUCKDB_PATH=data/truescout.duckdb
PARQUET_BRONZE_DIR=data/bronze
PARQUET_SILVER_DIR=data/silver
PARQUET_GOLD_DIR=data/gold

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# ---------------------------------------------------------------------------
# CORS  (JSON array — add your Vercel preview URL in production)
# ---------------------------------------------------------------------------
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ---------------------------------------------------------------------------
# Modeling
# ---------------------------------------------------------------------------
MC_ITERATIONS=10000
# Players below this confidence score are routed to the "Traditional Scout"
# LLM voice instead of the metrics-driven "Data Analyst" voice.
CONFIDENCE_SCORE_THRESHOLD=0.4
# Narrative-specific routing threshold (>= → Data Analyst; < → Traditional Scout)
NARRATIVE_CONFIDENCE_THRESHOLD=0.7
